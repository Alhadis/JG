{
	"extends": "@alhadis/eslint-config",
	"env": {
		"es2024": false,
		"mocha": false,
		"node": false
	},
	"noInlineConfig": false,
	"parserOptions": {
		"ecmaVersion": 5,
		"sourceType": "script"
	},
	"rules": {
		"comma-dangle": 0,
		"func-style": 0,
		"logical-assignment-operators": 0,
		"no-new-native-nonconstructor": 0,
		"no-self-compare": 0,
		"no-var": 0,
		"no-with": 0,
		"prefer-arrow-callback": 0,
		"prefer-const": 0,
		"prefer-destructuring": 0,
		"prefer-object-has-own": 0,
		"prefer-object-spread": 0,
		"prefer-rest-params": 0,
		"prefer-spread": 0,
		"vars-on-top": 0
	}
}
