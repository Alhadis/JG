{
	"$schema": "https://dprint.dev/schemas/v0.json",
	"projectType": "openSource",
	"lineWidth": 120,
	"newLineKind": "lf",
	"indentWidth": 4,
	"useTabs": true,
	"includes": [
		"**/*.dockerfile",
		"**/*.{css,scss,sass,less}",
		"**/*.{htm,html,shtml,xhtml}",
		"**/*.{svelte,vue,astro,j2,jinja,jinja2,twig,njk,vto,mustache}",
		"**/*.{gql,graphql,graphqls,prisma}",
		"**/*.{jmd,markdown,mdown,mdwn,mdx,md,mkdn,mkdown,mkd,rmd,ronn,ron,workbook}",
		"**/*.{py,py3,rpy,pyw,cpy,pyi,gyp,gypi,wsgi,tac,kv,SConstruct,SConscript,Snakefile}",
		"**/*.{yml,yaml,yaml-tmlanguage,clang-format,clang-tidy,clangd,gemrc,sublime-syntax,syntax}",
		"**/*.{CITATION.cff,glide.lock,pixi.lock,yarn.lock}",
		"**/*.{ts,tsx,js,jsx,mjs,cjs}",
		"**/*.{babel,bower}rc",
		"**/*.{js,html,styl}{h,l}intrc",
		"**/*.languagebabel",
		"**/*.{ld,geo,topo,}json{,l,ld}",
		"**/{*.ipynb,Notebook,Pipfile}",
		"**/*.php{,_cs,3,4,5,t}",
		"**/*.toml{,.example,.orig}",
		"**/{Cargo,Gopkg,pdm,poetry,uv}.lock",
		"**/*.tern-{config,project}",
		"**/*.web{app,manifest}",
		"**/*.rs{,.in}"
	],
	"excludes": [
		"**/{node_modules,coverage}",
		"**/*-lock.json"
	],
	"plugins": [
		"https://plugins.dprint.dev/dockerfile-0.3.3.wasm",
		"https://plugins.dprint.dev/g-plane/malva-v0.15.3.wasm",
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.0.wasm",
		"https://plugins.dprint.dev/g-plane/pretty_graphql-v0.2.3.wasm",
		"https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
		"https://plugins.dprint.dev/json-0.21.3.wasm",
		"https://plugins.dprint.dev/jupyter-0.2.2.wasm",
		"https://plugins.dprint.dev/mago-0.15.0.wasm",
		"https://plugins.dprint.dev/markdown-0.21.1.wasm",
		"https://plugins.dprint.dev/ruff-0.7.10.wasm",
		"https://plugins.dprint.dev/toml-0.7.0.wasm",
		"https://plugins.dprint.dev/typescript-0.95.15.wasm"
	],
	"dockerfile": {
		"lineWidth": 80,
		"newLineKind": "lf"
	},
	"graphql": {
		"braceSpacing": false,
		"bracketSpacing": false,
		"comma": "onlySingleLine",
		"formatComments": true,
		"ignoreCommentDirective": "dprint-ignore",
		"indentWidth": 4,
		"lineBreak": "lf",
		"parenSpacing": false,
		"printWidth": 80,
		"singleLine": "smart",
		"useTabs": true
	},
	"json": {
		"array.preferSingleLine": true,
		"commentLine.forceSpaceAfterSlashes": true,
		"indentWidth": 4,
		"newLineKind": "lf",
		"object.preferSingleLine": false,
		"useTabs": true
	},
	"mago": {
		"alignAssignmentLike": true,
		"alwaysBreakAttributeNamedArgumentLists": false,
		"alwaysBreakNamedArgumentsList": false,
		"arrayTableStyleAlignment": true,
		"breakPromotedPropertiesList": true,
		"classlikeBraceStyle": "same-line",
		"closureBraceStyle": "same-line",
		"controlBraceStyle": "same-line",
		"emptyLineAfterClassLikeConstant": false,
		"emptyLineAfterControlStructure": true,
		"emptyLineAfterDeclare": true,
		"emptyLineAfterEnumCase": false,
		"emptyLineAfterMethod": true,
		"emptyLineAfterNamespace": true,
		"emptyLineAfterOpeningTag": true,
		"emptyLineAfterProperty": false,
		"emptyLineAfterSymbols": false,
		"emptyLineAfterTraitUse": false,
		"emptyLineAfterUse": true,
		"emptyLineBeforeDanglingComments": true,
		"emptyLineBeforeReturn": false,
		"emptyLineBetweenSameSymbols": false,
		"endOfLine": "lf",
		"expandUseGroups": true,
		"firstMethodChainOnNewLine": true,
		"functionBraceStyle": "same-line",
		"inlineEmptyAnonymousClassBraces": true,
		"inlineEmptyClasslikeBraces": true,
		"inlineEmptyClosureBraces": true,
		"inlineEmptyConstructorBraces": true,
		"inlineEmptyControlBraces": true,
		"inlineEmptyFunctionBraces": true,
		"inlineEmptyMethodBraces": true,
		"lineBeforeBinaryOperator": true,
		"methodBraceStyle": "same-line",
		"methodChainBreakingStyle": "next-line",
		"nullTypeHint": "question",
		"parenthesesAroundNewInMemberAccess": false,
		"parenthesesInAttribute": false,
		"parenthesesInExitAndDie": true,
		"parenthesesInNewExpression": true,
		"phpVersionMajor": 7,
		"phpVersionMinor": 0,
		"phpVersionPatch": 4,
		"preserveBreakingArgumentList": false,
		"preserveBreakingArrayLike": false,
		"preserveBreakingAttributeList": true,
		"preserveBreakingConditionalExpression": false,
		"preserveBreakingMemberAccessChain": false,
		"preserveBreakingParameterList": false,
		"printWidth": 150,
		"removeTrailingCloseTag": true,
		"separateClassLikeMembers": true,
		"separateUseTypes": true,
		"singleQuote": false,
		"sortClassMethods": false,
		"sortUses": true,
		"spaceAfterAdditiveUnaryPrefixOperator": false,
		"spaceAfterBitwiseNotUnaryPrefixOperator": false,
		"spaceAfterCastUnaryPrefixOperators": true,
		"spaceAfterDecrementUnaryPrefixOperator": false,
		"spaceAfterErrorControlUnaryPrefixOperator": false,
		"spaceAfterIncrementUnaryPrefixOperator": false,
		"spaceAfterLogicalNotUnaryPrefixOperator": false,
		"spaceAfterReferenceUnaryPrefixOperator": false,
		"spaceAroundAssignmentInDeclare": false,
		"spaceAroundConcatenationBinaryOperator": true,
		"spaceBeforeArrowFunctionParameterListParenthesis": false,
		"spaceBeforeClosureParameterListParenthesis": false,
		"spaceBeforeClosureUseClauseParenthesis": true,
		"spaceBeforeHookParameterListParenthesis": true,
		"spaceWithinGroupingParenthesis": false,
		"tabWidth": 4,
		"trailingComma": true,
		"useTabs": true
	},
	"malva": {
		"attrValueQuotes": "always",
		"blockSelectorLinebreak": "consistent",
		"declarationOrder": "concentric",
		"declarationOrderGroupBy": "nonDeclarationAndEmptyLine",
		"formatComments": false,
		"hexCase": "lower",
		"hexColorLength": "short",
		"ignoreCommentDirective": "dprint-ignore",
		"ignoreFileCommentDirective": "dprint-ignore-file",
		"indentWidth": 4,
		"keyframeSelectorNotation": "keyword",
		"lineBreak": "lf",
		"linebreakInPseudoParens": true,
		"omitNumberLeadingZero": true,
		"operatorLinebreak": "before",
		"preferSingleLine": true,
		"printWidth": 80,
		"quotes": "preferDouble",
		"singleLineBlockThreshold": null,
		"singleLineTopLevelDeclarations": false,
		"trailingComma": true,
		"useTabs": true
	},
	"markdown": {
		"emphasisKind": "asterisks",
		"headingKind": "setext",
		"lineWidth": 80,
		"newLineKind": "lf",
		"strongKind": "asterisks",
		"textWrap": "always",
		"unorderedListKind": "asterisks"
	},
	"markup": {
		"angularNextControlFlowSameLine": false,
		"astroAttrShorthand": false,
		"closingBracketSameLine": false,
		"closingTagLineBreakForEmpty": "never",
		"component.selfClosing": true,
		"doctypeKeywordCase": "upper",
		"formatComments": false,
		"html.normal.selfClosing": false,
		"html.void.selfClosing": true,
		"ignoreCommentDirective": "dprint-ignore",
		"ignoreFileCommentDirective": "dprint-ignore-file",
		"indentWidth": 4,
		"lineBreak": "lf",
		"mathml.selfClosing": true,
		"preferAttrsSingleLine": true,
		"printWidth": 200,
		"quotes": "double",
		"scriptFormatter": "dprint",
		"scriptIndent": true,
		"singleAttrSameLine": true,
		"strictSvelteAttr": true,
		"styleIndent": true,
		"svelteAttrShorthand": false,
		"svelteDirectiveShorthand": false,
		"svg.selfClosing": true,
		"useTabs": true,
		"vBindSameNameShortHand": false,
		"vBindStyle": "long",
		"vForDelimiterStyle": "of",
		"vOnStyle": "long",
		"vSlotStyle": "long",
		"vueComponentCase": "ignore",
		"whitespaceSensitivity": "css"
	},
	"ruff": {
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineEnding": "lf",
		"lineLength": 120,
		"quoteStyle": "double",
		"skipMagicTrailingComma": false
	},
	"toml": {
		"cargo.applyConventions": true,
		"comment.forceLeadingSpace": true,
		"indentWidth": 4,
		"lineWidth": 80,
		"newLineKind": "lf",
		"useTabs": true
	},
	"typescript": {
		"arrowFunction.useParentheses": "preferNone",
		"binaryExpression.linePerExpression": false,
		"binaryExpression.spaceSurroundingBitwiseAndArithmeticOperator": true,
		"bracePosition": "sameLine",
		"commentLine.forceSpaceAfterSlashes": true,
		"constructor.spaceBeforeParentheses": false,
		"constructorType.spaceAfterNewKeyword": true,
		"constructSignature.spaceAfterNewKeyword": false,
		"deno": false,
		"doWhileStatement.spaceAfterWhileKeyword": false,
		"enumDeclaration.memberSpacing": "newLine",
		"exportDeclaration.spaceSurroundingNamedExports": true,
		"forInStatement.spaceAfterForKeyword": false,
		"forOfStatement.spaceAfterForKeyword": false,
		"forStatement.spaceAfterForKeyword": false,
		"forStatement.spaceAfterSemiColons": true,
		"functionDeclaration.spaceBeforeParentheses": false,
		"functionExpression.spaceAfterFunctionKeyword": false,
		"functionExpression.spaceBeforeParentheses": false,
		"getAccessor.spaceBeforeParentheses": false,
		"ifStatement.spaceAfterIfKeyword": false,
		"ignoreFileCommentText": "dprint-ignore-file",
		"ignoreNodeCommentText": "dprint-ignore",
		"importDeclaration.spaceSurroundingNamedImports": false,
		"jsxExpressionContainer.spaceSurroundingExpression": true,
		"locked": true,
		"memberExpression.linePerExpression": false,
		"method.spaceBeforeParentheses": false,
		"nextControlFlowPosition": "nextLine",
		"objectExpression.spaceSurroundingProperties": false,
		"objectPattern.spaceSurroundingProperties": false,
		"operatorPosition": "nextLine",
		"preferHanging": false,
		"preferSingleLine": false,
		"quoteStyle": "preferDouble",
		"semiColons": "always",
		"setAccessor.spaceBeforeParentheses": false,
		"singleBodyPosition": "sameLine",
		"spaceSurroundingProperties": false,
		"taggedTemplate.spaceBeforeLiteral": true,
		"trailingCommas": "onlyMultiLine",
		"typeAnnotation.spaceBeforeColon": false,
		"typeAssertion.spaceBeforeExpression": true,
		"typeLiteral.separatorKind": "semiColon",
		"typeLiteral.spaceSurroundingProperties": true,
		"useBraces": "preferNone",
		"whileStatement.spaceAfterWhileKeyword": false
	},
	"yaml": {
		"braceSpacing": false,
		"bracketSpacing": false,
		"dashSpacing": "oneSpace",
		"flowMap.preferSingleLine": false,
		"flowSequence.preferSingleLine": true,
		"formatComments": false,
		"ignoreCommentDirective": "dprint-ignore",
		"indentBlockSequenceInMap": true,
		"indentWidth": 4,
		"lineBreak": "lf",
		"preferSingleLine": false,
		"printWidth": 80,
		"proseWrap": "preserve",
		"quotes": "preferDouble",
		"trailingComma": false,
		"trimTrailingWhitespaces": true,
		"trimTrailingZero": true
	}
}
